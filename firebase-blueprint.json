{
  "entities": {
    "Sticker": {
      "title": "Sticker",
      "description": "A sticker in the user's album.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner." },
        "code": { "type": "string", "description": "The sticker code in the format SIGLA-NN, for example BRA-01 or FWC-19." },
        "count": { "type": "integer", "description": "How many of this sticker the user has (1 = owned, >1 = duplicates)." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the sticker was last updated." }
      },
      "required": ["uid", "code", "count", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "The user's profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "totalOwned": { "type": "integer", "description": "Total unique stickers owned." },
        "totalDuplicates": { "type": "integer", "description": "Total duplicate stickers." }
      },
      "required": ["uid", "email", "totalOwned", "totalDuplicates"]
    }
  },
  "firestore": {
    "/stickers/{stickerId}": {
      "schema": "Sticker",
      "description": "Collection of stickers owned by users."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    }
  }
}
